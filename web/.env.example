# Copy to .env and fill in real values. Never commit .env.
# These are injected into the Vite build at compile time (VITE_ prefix).

# Auth0 application credentials.
VITE_AUTH0_DOMAIN=ombuddi-alpha.us.auth0.com
VITE_AUTH0_CLIENT_ID=dlr8StIsreYV1m7DmMxC5FBiGf1ZyJ4R
# Set to the API Identifier from Auth0 → APIs (required for JWT access tokens).
VITE_AUTH0_AUDIENCE=

# Base URL of the Flask API (no trailing slash, no /api/v1 suffix).
VITE_API_URL=http://localhost:5002
