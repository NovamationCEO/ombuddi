# Copy this file to .env and fill in real values. Do not commit .env.
# These are read by service/docker-compose.yml and src/connection.py / hash_name.py.

# Postgres credentials — used by both the `db` and `app` containers.
DB_USER=ombuddi-dev
DB_PASS=change-me-to-a-real-password
DB_NAME=ombuddi-db
DB_URL=postgres://ombuddi-dev:change-me-to-a-real-password@db:5432/ombuddi-db

# Server-side salt mixed into every person hash (see service/src/hash_name.py).
# DO NOT rotate after any persons exist — every hashed_name row becomes unfindable.
# Pick something long and random for new deployments.
SALT=change-me-to-a-long-random-string
